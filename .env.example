# Config for neru backend — copy to `.env` and adjust. Never commit the real `.env`.

# Local Anthropic-format proxy. No real API key needed; the key is a dummy the
# SDK requires but the proxy does not check.
ANTHROPIC_API_KEY=sk-local-proxy
NEURU_LLM_BASE_URL=http://localhost:3456
# Model served by the proxy. Current proxy serves opus-4-7/4-6, sonnet-4-6, haiku-4-5.
NEURU_LLM_MODEL=claude-opus-4-7

# Voice-clone reference for TTS. Defaults to the bundled Neuro-sama reference
# (backend/assets/voices/neuro_ref.wav). Set to a path to clone a different voice,
# or leave empty (NEURU_TTS_VOICE_PROMPT=) to use Chatterbox's default voice.
# NEURU_TTS_VOICE_PROMPT=
